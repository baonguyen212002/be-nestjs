# Copy this file to `.env` and fill in real values.
# Never put real secrets in this file — it is committed to git.

MONGODB_URI=mongodb://localhost:27017/nest

# --- JWT ---
# Generate strong random secrets, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_REMEMBER_EXPIRES_IN=30d

# --- App / links (used in verification & reset emails) ---
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# --- Admin seed ---
ADMIN_EMAIL=admin@shop.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Administrator

# --- Mail (SMTP). Leave SMTP_HOST empty in dev to log links to console ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="No Reply <no-reply@shop.com>"
